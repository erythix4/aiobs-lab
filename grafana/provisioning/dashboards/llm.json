    {
      "type": "row",
      "id": 100,
      "title": "TTFT et Latence - Pipeline Drift",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "collapsed": false
    },
    {
      "type": "heatmap",
      "id": 11,
      "title": "Heatmap TTFT - outliers invisibles dans la moyenne",
      "description": "Un P99 eleve pendant que la moyenne est stable = pipeline drift",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "uid": "vm"
      },
      "options": {
        "calculate": false,
        "color": {
          "scheme": "Oranges",
          "mode": "scheme",
          "steps": 64
        },
        "yAxis": {
          "unit": "s",
          "decimals": 2
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "scheme",
            "colorScheme": "Oranges"
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "uid": "vm"
          },
          "expr": "sum by (le) (rate(llm_ttft_seconds_bucket[1m]))",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 12,
      "title": "TTFT P50 / P95 / P99 par modele",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "uid": "vm"
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull",
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "P99.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "P50.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "uid": "vm"
          },
          "expr": "histogram_quantile(0.50, sum by (le,model) (rate(llm_ttft_seconds_bucket[2m])))",
          "legendFormat": "P50 - {{model}}"
        },
        {
          "datasource": {
            "uid": "vm"
          },
          "expr": "histogram_quantile(0.95, sum by (le,model) (rate(llm_ttft_seconds_bucket[2m])))",
          "legendFormat": "P95 - {{model}}"
        },
        {
          "datasource": {
            "uid": "vm"
          },
          "expr": "histogram_quantile(0.99, sum by (le,model) (rate(llm_ttft_seconds_bucket[2m])))",
          "legendFormat": "P99 - {{model}}"
        }
      ]
    },
