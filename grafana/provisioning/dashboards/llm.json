{
  "title": "LLM Observability",
  "uid": "llm-obs",
  "description": " - Observabilite LLM en production",
  "tags": [
    "llm",
    "erythix"
  ],
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timezone": "browser",
  "schemaVersion": 38,
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "name": "model",
        "type": "query",
        "datasource": {
          "uid": "vm"
        },
        "definition": "label_values(llm_requests_total, model)",
        "query": "label_values(llm_requests_total, model)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "label": "Modele",
        "hide": 0,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "id": 1,
      "title": "Sante en temps reel",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "type": "stat",
      "id": 8,
      "title": "Sessions actives",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "uid": "vm"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "teal"
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "uid": "vm"
          },
          "expr": "llm_active_sessions",
          "legendFormat": "sessions"
        }
      ]
    },
    {
      "type": "stat",
      "id": 3,
      "title": "TTFT P99",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
